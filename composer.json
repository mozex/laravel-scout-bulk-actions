{
    "name": "mozex/laravel-scout-bulk-actions",
    "description": "A Laravel Scout extension for bulk importing and flushing of all models.",
    "keywords": [
        "laravel",
        "scout",
        "bulk",
        "batch",
        "search",
        "import",
        "indexing",
        "searchable",
        "full-text-search",
        "mass-import",
        "bulk-import",
        "eloquent"
    ],
    "homepage": "https://github.com/mozex/laravel-scout-bulk-actions",
    "license": "MIT",
    "authors": [
        {
            "name": "Mozex",
            "email": "hello@mozex.dev",
            "homepage": "https://mozex.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2.0",
        "laravel/framework": "^11.29|^12.12",
        "laravel/prompts": "^0.1.15|^0.2.0|^0.3.4",
        "laravel/scout": "^10.12.2",
        "spatie/laravel-package-tools": "^1.19.0"
    },
    "require-dev": {
        "laravel/pint": "^1.22.0",
        "orchestra/testbench": "^9.2|^10.0",
        "pestphp/pest": "^3.8.2|^4.0.0",
        "pestphp/pest-plugin-arch": "^3.1.1|^4.0.0",
        "phpstan/phpstan": "^2.1",
        "spatie/ray": "^1.41"
    },
    "autoload": {
        "psr-4": {
            "Mozex\\ScoutBulkActions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mozex\\ScoutBulkActions\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mozex\\ScoutBulkActions\\ScoutBulkActionsServiceProvider"
            ]
        }
    },
    "scripts": {
        "lint": "pint -v",
        "test:lint": "pint --test -v",
        "test:types": "phpstan analyse --ansi",
        "test:unit": "pest --colors=always",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    }
}
